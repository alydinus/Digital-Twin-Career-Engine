# Скопируй этот файл в .env и заполни ключи (если нужен LLM-режим)

# Провайдер: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# API-ключ выбранного провайдера
LLM_API_KEY=

# (опц.) Переопределить модель по умолчанию
# LLM_MODEL=gemini-1.5-flash

# GitHub токен (опционально — для GitHub Search API и Agent Web Browsing)
GITHUB_TOKEN=

# ─── NotebookLM MCP Bridge (Platform Layer) ──────────────────────────────────
# Ссылка на NotebookLM notebook (Share → Copy link)
NOTEBOOKLM_URL=
# MCP сервер (по умолчанию localhost:3100)
# NOTEBOOKLM_MCP_HOST=localhost
# NOTEBOOKLM_MCP_PORT=3100

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Токен бота — получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# ─── Telegram Job Scraper (парсинг каналов) ──────────────────────────────────
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+7XXXXXXXXXX
